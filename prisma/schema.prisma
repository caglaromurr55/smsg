generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String    @id @default(cuid())
  name      String
  passcode  String    @unique
  role      String    @default("agent")
  avatar    String?
  messages  Message[]
}

model Message {
  id        String   @id @default(cuid())
  content   String
  mediaUrl  String?
  createdAt DateTime @default(now())
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id])
}
